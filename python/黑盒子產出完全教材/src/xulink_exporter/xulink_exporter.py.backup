import pandas as pd  # 匯入超強力資料表與 Excel 處置霸主模組，用於輸出結構化資料
from typing import List, Dict  # 匯入靜態型別標籤符號功能，強化程式碼的可讀性與型別安全

def export_to_excel(list_questions: List[Dict], str_filename: str = "training_question_bank.xlsx"):  # 設計一個轉大表的巨型引擎函式，負責將考題陣列轉為 Excel 檔
    """
    Export questions to XuLink compatible Excel format.
    Follows the format specified in test_rule.md
    """  # 函式說明文件字串，指出此功能為匯出符合旭聯平台規範之題庫檔案
    list_rows = []  # 陣列型字典變數，開闢一個非常廣袤空地準備存放準備寫入 Excel 內的資料列紀錄

    for dict_question in list_questions:  # 字典變數，逐一審閱從產線端出的每一道考題字典內容
        # Add question header row...
        dict_question_row = {  # 字典變數，為遵照旭聯老舊格式必須首位建置獨享的一行霸權所謂題目標題列
            "#Qtype": dict_question.get("type", ""),  # 字串變數，填入考題種別身分證明（如單選或是非題標籤）
            "Subject": dict_question.get("subject", ""),  # 字串變數，正式把問題考幹文宣謄寫而上作為主體
            "Option": "",  # 字串變數，首行題干本身絕不能夾雜選項文字故採清白空格處理
            "Weight": dict_question.get("weight", 1),  # 數值變數，賦予本題的原始價值與加權分數配置資訊
            "Difficulty": dict_question.get("difficulty", 3),  # 數值變數，將難關障礙等第評分轉交給這行紀錄保存
            "Answer": "",  # 字串變數，第一列為了防範洩露解答嫌疑一樣保持封印空字串
            "Option Limit Type": dict_question.get("option_limit_type", 0),  # 數值變數，設定對該考題所施加之限制模式編碼
            "Option Limit Count": dict_question.get("option_limit_count", 0),  # 數值變數，定義受限的總量或字數之真實數字
            "Analyze(for QBank)": dict_question.get("analyze", ""),  # 字串變數，留下所謂背後真諦答案解析之說明文字
            "NoRandom(for QBank)": dict_question.get("no_random", 0)  # 數值變數，指示平台是否禁止亂序攪局之防駭模式鎖
        }  # 結束題目標題列定義
        list_rows.append(dict_question_row)  # 指令，將這華麗的第一列加入大集合成為該題之領軍先鋒

        # Add option rows...
        if "options" in dict_question:  # 邏輯判斷，若這題具備複數選項分支路口（如非申論題型）時
            for int_i, str_option in enumerate(dict_question["options"]):  # 整數與字串變數，將選項一個個取出並附上排序編號
                bool_is_correct = False  # 布林變數，出門在外總先假設所有人都是錯的清白假定原理
                
                # Handle different answer formats...
                if isinstance(dict_question.get("answer"), str):  # 邏輯判斷，若標準答案是直覺的單一字串格式
                    bool_is_correct = (str_option == dict_question.get("answer"))  # 布林運算，兩者一對比若一樣則冊封為正確選項
                elif isinstance(dict_question.get("answer"), list):  # 邏輯判斷，若標準答案採高規格清單陣列格式封裝
                    bool_is_correct = (str_option in dict_question.get("answer", []))  # 布林運算，檢查目前選項是否在正確清單名錄內
                
                str_answer_mark = "y" if bool_is_correct else ""  # 字串變數，配合舊系統僅認小寫 y 作為解答印記，不對即空白
                
                dict_option_row = {  # 字典變數，為這選項建置伴隨主將的一系列專屬隨從列資料
                    "#Qtype": "",  # 字串變數，隨列無權重複決定題型身分
                    "Subject": "",  # 字串變數，已經講過的問題主幹不可復刻重複出現
                    "Option": str_option,  # 字串變數，只有在這個欄位它能展示它的選項魅力內文
                    "Weight": "",  # 數值格式，評比總權在首無關細微小卒故空白
                    "Difficulty": "",  # 數值格式，同上權限不足無須過問
                    "Answer": str_answer_mark,  # 字串變數，小寫解答印記決定了成敗標籤在此處呈現
                    "Option Limit Type": "",  # 數值格式，無管轄權故留白
                    "Option Limit Count": "",  # 數值格式，無實權故留白
                    "Analyze(for QBank)": "",  # 字串格式，歸於平靜空白不重複說明
                    "NoRandom(for QBank)": ""  # 數值格式，不得在此處造訪設定
                }  # 結束選項列定義
                list_rows.append(dict_option_row)  # 指令，將後備子弟兵也都全數收編進大行列中與主將匯流

    # Create DataFrame with correct column order...
    df_excel = pd.DataFrame(list_rows, columns=[  # DataFrame 變數，呼叫熊貓神獸幫這龐大陣列鑄入表格中
        "#Qtype", "Subject", "Option", "Weight", "Difficulty", "Answer",  # 清單字串，定義上半段黃金比例名錄標頭
        "Option Limit Type", "Option Limit Count", "Analyze(for QBank)", "NoRandom(for QBank)"  # 清單字串，定義下半段必帶標頭名稱
    ])  # 結束表格物件建立

    # Save to Excel...
    df_excel.to_excel(str_filename, index=False, sheet_name='Questions')  # 指令，將資料寫入實體檔案並附上分頁名標籤
    
    return str_filename  # 回傳值，大功告成將刻好的結果檔名送交至外部世界
